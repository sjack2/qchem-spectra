# ============================================================
# Q-Chem pipeline — output data (cluster-only, never committed)
# ============================================================

# Per-molecule output trees (all pipeline stages)
pna/

# Generic catch-all for any other molecule directories
# (matches any dir that looks like a pipeline output tree)
*/01_gas_opt/
*/02_conf_search/
*/03_solvent_opt/
*/04_boltzmann/
*/05_ecd/
*/05_vcd/
*/06_spectra/

# Track starter geometries inside pre_xyz/
!pre_xyz/
!pre_xyz/*.xyz

# Cluster-specific configuration (site paths must not be committed)
cluster.cfg

# Claude Code local settings (machine-specific)
.claude/

# Q-Chem scratch and temp files
*.tmp
slurm-*.out
slurm-*.err

# Python cache
__pycache__/
*.pyc
