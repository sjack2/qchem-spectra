# =============================================================================
# cluster.cfg.example — site-specific configuration for qchem-spectra
# =============================================================================
#
# Copy this file to cluster.cfg and fill in the values for your cluster.
#
#   cp cluster.cfg.example cluster.cfg
#
# cluster.cfg is gitignored (site-specific paths should not be committed).
# cluster.cfg.example is committed to the repo as a template.
#
# All variables are optional. Unset variables fall back to built-in defaults
# or can be overridden at run time with explicit CLI flags.
# CLI flag > cluster.cfg > built-in default.
#
# =============================================================================

# Full path to the Q-Chem setup script (typically called "setqc" or
# "qchem.setup"). Sourcing this script sets QC, QCAUX, PATH, and any
# other environment variables Q-Chem needs at runtime.
# Equivalent to passing --qchem-setup on every invocation.
#
# Example:
#   QCHEM_SETUP=/shares/chem_hlw/qchem/qchem_6.2/setqc
#
QCHEM_SETUP=

# Default SLURM partition for job submission.
# Equivalent to passing --partition on every invocation.
#
# USF CIRCE:   general
# Other sites: gpu, short, compute, ...
#
CLUSTER_PARTITION=general

# Default SLURM wall-clock time limit (HH:MM:SS).
# Equivalent to passing --time on every invocation.
# Each script has its own stage-appropriate default; set this only if you
# want a single global override.
#
CLUSTER_WALL=06:00:00

# Extra library directories prepended to LD_LIBRARY_PATH in each SLURM job.
# Q-Chem uses shared-memory (OpenMP) parallelism, so no MPI installation is
# needed. However, CLUSTER_LD_LIBRARY_PATH may still be required depending
# on how Q-Chem was compiled:
#
#   Intel-compiled Q-Chem (most common):
#     Needs libiomp5.so (Intel OpenMP runtime) and a libstdc++.so.6 new
#     enough to match the GCC used during compilation. Add both the Intel
#     compiler lib directory and a sufficiently new GCC lib64 directory.
#     Example:
#       CLUSTER_LD_LIBRARY_PATH=/path/to/intel/compiler/lib:/path/to/gcc-X.Y.Z/lib64
#
#   GCC-compiled Q-Chem:
#     Only needs a compatible libstdc++.so.6 if the compute nodes run an
#     older OS than the build host.
#     Example:
#       CLUSTER_LD_LIBRARY_PATH=/path/to/gcc-X.Y.Z/lib64
#
# Leave unset if the compute nodes already have all required libraries in
# their default environment.
#
CLUSTER_LD_LIBRARY_PATH=
